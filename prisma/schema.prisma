generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  password        String?
  name            String?
  phone           String?
  isVerified      Boolean     @default(false)
  profileKey      String?
  ayrshareUserId  String?
  tokenBalance    Int         @default(50)
  tokenUsed       Int         @default(0)
  trialEndsAt     DateTime?
  mamoCustomerId  String?
  referralCode    String?     @unique
  referredByCode  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  refreshTokens     RefreshToken[]
  verifyTokens      VerifyToken[]
  resetTokens       ResetToken[]
  magicTokens       MagicToken[]
  activity          Activity?
  preference        Preference?
  dataImages        DataImage[]
  campaigns         Campaign[]
  socialAccounts    SocialAccount[]
  posts             Post[]
  tokenLogs         TokenLog[]
  subscription      UserSubscription?
  payments          Payment[]
  referralsSent     Referral[]  @relation("referrer")
  referralsReceived Referral?   @relation("referee")
  strategies        Strategy[]
  actionTasks       ActionTask[]
  competitors       Competitor[]
}

model Referral {
  id            String   @id @default(cuid())
  referrerId    String
  referrer      User     @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId     String   @unique
  referee       User     @relation("referee", fields: [refereeId], references: [id], onDelete: Cascade)
  tokensAwarded Int      @default(50)
  status        String   @default("pending")
  createdAt     DateTime @default(now())
}

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  monthlyPrice  Int
  yearlyPrice   Int
  tokenCount    Int
  platformLimit Int      @default(3)
  features      String
  locked        String   @default("[]")
  watermark     Boolean  @default(false)
  popular       Boolean  @default(false)
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id                 String    @id @default(cuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId             String
  plan               Plan      @relation(fields: [planId], references: [id])
  status             String    @default("active")
  billingType        String    @default("monthly")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  mamoSubscriptionId String?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Int
  currency          String   @default("SAR")
  status            String
  provider          String   @default("mamopay")
  providerPaymentId String?
  type              String
  description       String?
  metadata          String?
  idempotencyKey    String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TokenPackage {
  id         String   @id @default(cuid())
  name       String
  tokenCount Int
  price      Int
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TokenLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  tokens      Int
  agent       String   @default("Content")
  createdAt   DateTime @default(now())
}

model Post {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    String
  caption     String    @db.Text
  hashtags    String?
  mediaUrls   String?
  scheduledAt DateTime?
  status      String   @default("Draft")
  ayrshareId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    String
  username    String?
  followers   Int      @default(0)
  connected   Boolean  @default(true)
  connectedAt DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@unique([userId, platform])
}

model Campaign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  status          String   @default("Scheduled")
  platforms       String
  budget          Int
  spent           Int      @default(0)
  reach           Int      @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  roi             Float?
  startDate       DateTime
  endDate         DateTime
  isAI            Boolean  @default(true)
  location        String?
  ageRange        String?
  interests       String?
  ayrsharePostIds String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
}

model Activity {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business_name        String?
  industry             String?
  country              String?
  location             String?
  opening_hours        String?
  business_size        String?
  year_founded         String?
  audience_target      String?
  unique_selling_point String?
  certifications       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())
}

model Preference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tone_of_voice        String?
  language_preference  String?
  business_description String?
  social_media_goals   String?
  color_primary        String?
  color_secondary      String?
  preferred_platforms  String?
  hashtags             String?
  emojis               String?
  other                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())
}

model Strategy {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String?
  status          String    @default("active")
  periodStartDate DateTime?
  periodEndDate   DateTime?
  weekCount       Int       @default(8)
  goal            String?   @db.Text
  platforms       String?
  n8nSessionId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  weeklyPlannings WeeklyPlanning[]
  actionTasks     ActionTask[]
}

model WeeklyPlanning {
  id            String    @id @default(cuid())
  strategyId    String
  strategy      Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  weekNumber    Int
  weekStartDate DateTime?
  weekEndDate   DateTime?
  postsCount    Int       @default(0)
  weeklyGoal    String?   @db.Text
  status        String   @default("pending")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  draftPosts DraftPost[]
}

model DraftPost {
  id               String         @id @default(cuid())
  weeklyPlanningId String
  weeklyPlanning   WeeklyPlanning @relation(fields: [weeklyPlanningId], references: [id], onDelete: Cascade)
  platform         String?
  caption          String?        @db.Text
  hashtags         String?
  mediaUrl         String?
  mediaType        String?
  postDate         DateTime?
  postTime         String?
  postDetails      String?        @db.Text
  postReminder     String?
  status           String         @default("draft")
  publishedPostId  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model DataImage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename  String
  mimetype  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model VerifyToken {
  id        String   @id @default(cuid())
  code      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MagicToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActionTask {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategyId  String?
  strategy    Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  title       String
  description String?
  platform    String?
  dueDate     DateTime?
  status      String    @default("pending")
  priority    String    @default("medium")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Competitor {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  platform      String
  handle        String
  followers     Int       @default(0)
  postsPerWeek  Float     @default(0)
  avgEngagement Float     @default(0)
  lastSynced    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}